{
  "hosting": [
    {
      "target": "admin",
      "public": ".",
      "ignore": [
        "firebase.json",
        ".firebaseignore",
        "node_modules",
        "node_modules/**",
        ".git",
        ".git/**",
        ".agents",
        ".agents/**",
        "package.json",
        "package-lock.json",
        "README.md",
        "skills-lock.json",
        "version1.2",
        "version1.2/**",
        "cliente",
        "cliente/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "**/*.@(js|css)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "max-age=31536000"
            }
          ]
        }
      ]
    },
    {
      "target": "cliente",
      "public": "cliente",
      "ignore": [
        "firebase.json",
        "**/.*"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
